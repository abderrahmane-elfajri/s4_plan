{
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run web:build",
    "frontendDist": "../dist"
  },
  "package": {
    "productName": "S4 Plan",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": true,
      "fs": {
        "all": true,
        "scope": ["$APPDIR/**"]
      },
      "window": {
        "all": true
      },
      "shell": {
        "all": true,
        "open": true
      }
    },
    "windows": [
      {
        "title": "S4 MIP Study Plan",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "trayIconPath": "",
        "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png"]
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:5173 https:;"
    }
  }
}
